{
  "rewrites": [
    {
      "source": "/privacy",
      "has": [
        {
          "type": "host",
          "value": "privacywhoop.bridgeintelligence.co"
        }
      ],
      "destination": "/privacy-whoop.html"
    },
    {
      "source": "/callback",
      "has": [
        {
          "type": "host",
          "value": "privacywhoop.bridgeintelligence.co"
        }
      ],
      "destination": "/whoop-callback.html"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "privacywhoop.bridgeintelligence.co"
        }
      ],
      "destination": "/privacy-whoop.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "privacywhoop.bridgeintelligence.co"
        }
      ],
      "destination": "/privacy",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "calvinbeighle.com"
        }
      ],
      "destination": "https://bridgeintelligence.co/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.calvinbeighle.com"
        }
      ],
      "destination": "https://bridgeintelligence.co/$1",
      "permanent": true
    }
  ]
}
